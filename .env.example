# Configuración de Deitafix (copiá a .env para desarrollo local).
# En producción estas variables las provee el orquestador; nunca commitees .env.

# Conexión con el usuario RESTRINGIDO (nunca el de la app).
# Postgres: postgres://prod_datafix:dev_datafix_pw@localhost:5432/deitafix_dev
# MySQL:    mysql://prod_datafix:dev_datafix_pw@localhost:3306/deitafix_dev
DATABASE_URL=postgres://prod_datafix:dev_datafix_pw@localhost:5432/deitafix_dev

# Motor: postgres | mysql. Si se omite, se infiere del esquema de DATABASE_URL.
DEITAFIX_ENGINE=postgres

# Feature flag maestro. Con false el servicio arranca pero responde 503.
DATAFIX_ENABLED=true

# Tope de filas afectadas; si el preview mide más, la operación se aborta.
MAX_AFFECTED_ROWS=50

# Whitelist de tablas separadas por coma (comparación exacta, sensible a mayúsculas).
TABLE_WHITELIST=CollectionBox

# Puerto HTTP (opcional; default 8080).
PORT=8080

# --- Capa MCP (opcional) ---
# Expone preview y confirm como herramientas MCP para que un agente de IA proponga
# escrituras, obligado a pasar por las mismas guardas y el mismo preview. El agente
# NUNCA ejecuta: el confirm humano sigue siendo de una persona (human-in-the-loop).

# On/off de la capa MCP. Con false, el endpoint /mcp no se registra.
MCP_ENABLED=false

# Bearer que protege el endpoint /mcp. OBLIGATORIO si MCP_ENABLED=true.
MCP_AUTH_TOKEN=

# Ruta del endpoint MCP (opcional; default /mcp).
MCP_PATH=/mcp

# Base pública para la approval_url que devuelve la herramienta confirm
# (opcional; p. ej. https://deitafix.midominio.com). Si se omite, la URL es relativa.
MCP_APPROVAL_BASE_URL=

# Bearer OPCIONAL que protege la superficie humana (UI + confirm + aprobaciones),
# para que la credencial MCP no la alcance. Recomendado si MCP está habilitado.
UI_AUTH_TOKEN=
